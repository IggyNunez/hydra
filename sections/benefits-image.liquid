{{ 'benefits-image.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    --benefits-bg: {{ section.settings.bg_color }};
    --benefits-heading-color: {{ section.settings.heading_color }};
    --benefits-text-color: {{ section.settings.text_color }};
    --benefits-btn-bg: {{ section.settings.btn_bg_color }};
    --benefits-btn-text: {{ section.settings.btn_text_color }};
    --benefits-btn-text-2: {{ section.settings.btn2_text_color }};
    --benefits-pt: {{ section.settings.padding_top }}px;
    --benefits-pb: {{ section.settings.padding_bottom }}px;
    --benefits-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --benefits-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --benefits-side-pad: {{ section.settings.side_padding }}px;
    --benefits-heading-size: {{ section.settings.heading_size }}px;
    --benefits-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --benefits-heading-weight: {{ section.settings.heading_weight }};
    --benefits-heading-ls: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --benefits-desc-size: {{ section.settings.desc_size }}px;
    --benefits-item-title-size: {{ section.settings.item_title_size }}px;
    --benefits-item-text-size: {{ section.settings.item_text_size }}px;
    --benefits-icon-border-color: {{ section.settings.icon_border_color }};
    --benefits-icon-bg: {{ section.settings.icon_bg_color }};
    --benefits-btn-font-size: {{ section.settings.btn_font_size }}px;
    --benefits-img-position: {{ section.settings.image_position }};
    --benefits-grid-cols: {{ section.settings.grid_cols }};
    --benefits-grid-gap: {{ section.settings.grid_gap }}px;
    --benefits-grid-gap-h: {{ section.settings.grid_gap_h }}px;
    --benefits-mobile-item-align: {{ section.settings.mobile_item_align }};
    --benefits-mobile-item-text-align: {% if section.settings.mobile_item_align == 'center' %}center{% else %}left{% endif %};
  }
{% endstyle %}

<section class="benefits-image{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  style="
    padding-top: var(--benefits-pt, 80px);
    padding-bottom: var(--benefits-pb, 80px);
  "
>
  <div class="benefits-image__inner"
    style="{% if section.settings.layout == 'image_left' %}direction: rtl;{% endif %}"
  >

    {%- comment -%} CONTENT {%- endcomment -%}
    <div class="benefits-image__content" style="
      direction: ltr;
      padding: var(--benefits-pt, 80px) var(--benefits-side-pad, 60px) var(--benefits-pb, 80px);
      text-align: {{ section.settings.content_alignment }};
      align-items: {% if section.settings.content_alignment == 'center' %}center{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    ">

      {%- if section.settings.heading != blank -%}
        <h2 class="benefits-image__heading" style="
          font-size: var(--benefits-heading-size, 44px);
          font-weight: var(--benefits-heading-weight, 700);
          letter-spacing: var(--benefits-heading-ls, -0.02em);
          margin-bottom: {{ section.settings.heading_mb }}px;
        ">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="benefits-image__desc" style="
          font-size: var(--benefits-desc-size, 17px);
          margin-bottom: {{ section.settings.desc_mb }}px;
        ">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="benefits-image__grid{% if section.settings.mobile_grid_cols == '1' %} benefits-image__grid--mobile-1col{% endif %}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <div class="benefits-image__item" {{ block.shopify_attributes }}>

                <div class="benefits-image__item-icon" style="
                  width: {{ section.settings.icon_size }}px;
                  height: {{ section.settings.icon_size }}px;
                  background-color: var(--benefits-icon-bg, transparent);
                  border-color: var(--benefits-icon-border-color, rgba(255,255,255,0.5));
                ">
                  {%- if block.settings.icon_image != blank -%}
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 56 }}"
                      alt="{{ block.settings.icon_image.alt | escape }}"
                      width="28" height="28" loading="lazy"
                    >
                  {%- else -%}
                    {%- case block.settings.icon_preset -%}
                      {%- when 'brain' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9.5 2a4.5 4.5 0 0 1 4.477 4H14a3 3 0 0 1 3 3v.5a2.5 2.5 0 0 1-2.5 2.5H14v1h.5A3.5 3.5 0 0 1 18 16.5V17a3 3 0 0 1-3 3H9a3 3 0 0 1-3-3v-.5A3.5 3.5 0 0 1 9.5 13H10v-1h-.5A2.5 2.5 0 0 1 7 9.5V9a3 3 0 0 1 3-3h.023A4.502 4.502 0 0 1 9.5 2z" stroke="#fff" stroke-width="1.5" fill="none"/></svg>
                      {%- when 'moon' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'no' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="#fff" stroke-width="1.5" fill="none"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" stroke="#fff" stroke-width="1.5"/></svg>
                      {%- when 'sugar' -%}
                        {%- comment -%} No Added Sugar — sugar cube with X {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="7" width="10" height="10" rx="1.5" stroke="#fff" stroke-width="1.5" fill="none" transform="rotate(-10 9 12)"/><rect x="7" y="9.5" width="3" height="3" rx="0.5" stroke="#fff" stroke-width="1" fill="none" transform="rotate(-10 8.5 11)"/><line x1="17" y1="3" x2="21" y2="7" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/><line x1="21" y1="3" x2="17" y2="7" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/></svg>
                      {%- when 'vegan' -%}
                        {%- comment -%} Vegan Formula — plant sprout in a circle {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9.5" stroke="#fff" stroke-width="1.5" fill="none"/><path d="M12 18V11" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/><path d="M12 11c0-3.5 3-5.5 5.5-5.5C17.5 9 14.5 11 12 11z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M12 14c0-2.5-2.5-4-4.5-4C7.5 12.5 9.5 14 12 14z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/></svg>
                      {%- when 'nongmo' -%}
                        {%- comment -%} Non-GMO — DNA helix with slash {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 3v1c0 2.2 1.3 4.2 3 5.2 1.7 1 3 3 3 5.2V21" stroke="#fff" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M15 3v1c0 2.2-1.3 4.2-3 5.2-1.7 1-3 3-3 5.2V21" stroke="#fff" stroke-width="1.5" fill="none" stroke-linecap="round"/><line x1="9.2" y1="6" x2="14.8" y2="6" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/><line x1="8" y1="12" x2="16" y2="12" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/><line x1="9.2" y1="18" x2="14.8" y2="18" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/><line x1="3" y1="21" x2="21" y2="3" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/></svg>
                      {%- when 'sparkle' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.6H22l-6.2 4.5 2.4 7.6L12 17.2l-6.2 4.5 2.4-7.6L2 9.6h7.6z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/></svg>
                      {%- when 'check' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 6L9 17l-5-5" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'leaf' -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 8C8 10 5.9 16.17 3.82 22c4.8-3 8.14-6.38 9.18-11 4.28.31 7.5 2.65 7.5 7 0 3-1.5 6-3.5 8" stroke="#fff" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'shield' -%}
                        {%- comment -%} Shield with checkmark {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l7 3.5v5c0 5-3 9.5-7 11-4-1.5-7-6-7-11v-5L12 2z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- when 'droplet' -%}
                        {%- comment -%} Water droplet {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.7c0 0-6.5 7.3-6.5 11.8a6.5 6.5 0 0 0 13 0C18.5 10 12 2.7 12 2.7z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M10 15.5c0-1.5 1-2.5 2-3" stroke="#fff" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
                      {%- when 'bolt' -%}
                        {%- comment -%} Lightning bolt / energy {%- endcomment -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M13 2L4.5 13H12l-1 9L19.5 11H12l1-9z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="4" stroke="#fff" stroke-width="1.5" fill="none"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </div>

                {%- if block.settings.title != blank -%}
                  <p class="benefits-image__item-title" style="font-size: var(--benefits-item-title-size, 15px);">
                    {{ block.settings.title }}
                  </p>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <p class="benefits-image__item-text" style="font-size: var(--benefits-item-text-size, 15px);">
                    {{ block.settings.text }}
                  </p>
                {%- endif -%}

              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.btn_label != blank or section.settings.btn2_label != blank -%}
        <div class="benefits-image__cta" style="margin-top: {{ section.settings.btn_mt }}px;">
          {%- if section.settings.btn_label != blank -%}
            <a href="{{ section.settings.btn_url }}" class="benefits-image__btn benefits-image__btn--primary">
              {{ section.settings.btn_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.btn2_label != blank -%}
            <a href="{{ section.settings.btn2_url }}" class="benefits-image__btn benefits-image__btn--secondary">
              {{ section.settings.btn2_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} IMAGE {%- endcomment -%}
    <div class="benefits-image__media{% if section.settings.product_image == blank %} benefits-image__media--placeholder{% endif %}"
      style="direction: ltr;"
    >
      {%- if section.settings.product_image != blank -%}
        <img
          src="{{ section.settings.product_image | image_url: width: 1200 }}"
          alt="{{ section.settings.product_image.alt | escape }}"
          width="{{ section.settings.product_image.width }}"
          height="{{ section.settings.product_image.height }}"
          loading="lazy"
          style="object-position: var(--benefits-img-position, center top);"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Benefits + Image",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_right", "label": "Image right (default)" },
        { "value": "image_left",  "label": "Image left" }
      ],
      "default": "image_right"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "options": [
        { "value": "center top",    "label": "Top center" },
        { "value": "center center", "label": "Center" },
        { "value": "center bottom", "label": "Bottom center" },
        { "value": "left center",   "label": "Left center" },
        { "value": "right center",  "label": "Right center" }
      ],
      "default": "center top"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0, "max": 200, "step": 4, "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0, "max": 200, "step": 4, "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0, "max": 120, "step": 4, "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0, "max": 120, "step": 4, "default": 48
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Content side padding (px)",
      "min": 0, "max": 120, "step": 4, "default": 60
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#263D87"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Hydra Works"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop, px)",
      "min": 18, "max": 90, "step": 2, "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile, px)",
      "min": 18, "max": 60, "step": 2, "default": 32
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": -10,
      "max": 50,
      "step": 1,
      "default": -2,
      "info": "Values in hundredths of an em (e.g. -2 = -0.02em)"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_mb",
      "label": "Space below heading (px)",
      "min": 0, "max": 60, "step": 2, "default": 20
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Over 200mg of electrolytes per serving. No added sugar, no artificial sweeteners, no dyes. Just pure hydration in a formula you can feel good about.</p>"
    },
    {
      "type": "range",
      "id": "desc_size",
      "label": "Description font size (px)",
      "min": 12, "max": 26, "step": 1, "default": 17
    },
    {
      "type": "range",
      "id": "desc_mb",
      "label": "Space below description (px)",
      "min": 0, "max": 80, "step": 2, "default": 40
    },
    {
      "type": "header",
      "content": "Benefit grid"
    },
    {
      "type": "select",
      "id": "grid_cols",
      "label": "Columns (desktop)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "mobile_grid_cols",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "mobile_item_align",
      "label": "Item alignment (mobile)",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center",     "label": "Center" }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Row gap (px)",
      "min": 8, "max": 80, "step": 2, "default": 36
    },
    {
      "type": "range",
      "id": "grid_gap_h",
      "label": "Column gap (px)",
      "min": 8, "max": 80, "step": 2, "default": 40
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon circle size (px)",
      "min": 32, "max": 100, "step": 2, "default": 56
    },
    {
      "type": "range",
      "id": "item_title_size",
      "label": "Benefit title size (px)",
      "min": 10, "max": 28, "step": 1, "default": 15
    },
    {
      "type": "range",
      "id": "item_text_size",
      "label": "Benefit description size (px)",
      "min": 10, "max": 22, "step": 1, "default": 15
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product / lifestyle image"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button 1 label"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button 2 label"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 link"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Button font size (px)",
      "min": 10, "max": 50, "step": 1, "default": 15
    },
    {
      "type": "range",
      "id": "btn_mt",
      "label": "Space above buttons (px)",
      "min": 0, "max": 80, "step": 2, "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & item title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body & item text color",
      "default": "#ffffffcc"
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon circle border color",
      "default": "#ffffff80"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon circle background color",
      "default": "#ffffff00"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button 1 background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button 1 text",
      "default": "#263D87"
    },
    {
      "type": "color",
      "id": "btn2_text_color",
      "label": "Button 2 text",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image",
          "info": "Upload a custom icon. If blank, a preset icon will be used."
        },
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Preset icon",
          "options": [
            { "value": "sugar",   "label": "No Added Sugar" },
            { "value": "vegan",   "label": "Vegan / Plant" },
            { "value": "nongmo",  "label": "Non-GMO" },
            { "value": "brain",   "label": "Brain" },
            { "value": "moon",    "label": "Moon" },
            { "value": "no",      "label": "No / Cancel" },
            { "value": "sparkle", "label": "Sparkle / Star" },
            { "value": "check",   "label": "Checkmark" },
            { "value": "leaf",    "label": "Leaf" },
            { "value": "shield",  "label": "Shield / Verified" },
            { "value": "droplet", "label": "Water Droplet" },
            { "value": "bolt",    "label": "Lightning / Energy" },
            { "value": "dot",     "label": "Dot (default)" }
          ],
          "default": "dot"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Short description of this benefit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits + Image",
      "settings": {
        "bg_color": "#263D87",
        "heading": "Why Hydra Works",
        "icon_border_color": "#61c2f480",
        "icon_bg_color": "#61c2f414"
