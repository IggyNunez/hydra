    "science_process_main": {
      "type": "science-process",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "title": "Collected from the Source",
            "text": "Mineral-rich water from the Great Salt Lake in Utah — one of the most mineral-dense inland bodies of water in the world — is collected."
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "title": "Placed in Solar Evaporation Ponds",
            "text": "The water is transferred into large solar evaporation ponds where the natural concentration process begins."
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "title": "Sun Concentrates the Minerals",
            "text": "Over the course of three years, the sun naturally concentrates the minerals as the water slowly evaporates."
          }
        },
        "step_4": {
          "type": "step",
          "settings": {
            "title": "Minerals Rise and Crystallize",
            "text": "As evaporation progresses, the mineral salts rise to the surface and crystallize — preserving the natural balance of electrolytes found in the lake."
          }
        },
        "step_5": {
          "type": "step",
          "settings": {
            "title": "Harvested and Purified",
            "text": "The mineral salts are harvested, purified, and independently lab tested to meet food-grade safety standards before going into every Hydra product."
          }
        }
      },
      "block_order": [
        "step_1",
        "step_2",
        "step_3",
        "step_4",
        "step_5"
      ],
