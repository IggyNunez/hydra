          "settings": {
            "feature": "Added Sugar",
            "brand_1_type": "text",
            "brand_1_text": "0g",
            "brand_2_type": "text_bad",
            "brand_2_text": "~11g",
            "brand_3_type": "text_bad",
            "brand_3_text": "~34g",
            "brand_4_type": "text",
            "brand_4_text": "0g"
          }
        },
        {
