:0,"margin_top":40,"margin_bottom":40}},"image_with_text_v1_FLrPrz":{"type":"image-with-text-v1","blocks":{"heading_NWakhK":{"type":"heading","settings":{"heading":"SOCIAL PROOF","heading_size":"h0"}},"text_xBg9Mk":{"type":"text","settings":{"text":"<p>🏆 Winner – GNC Next Big Thing Competition<br\/><br\/>🛒 Sprouts<br\/><br\/>🚚 GoPuff<br\/><br\/>📦 Amazon<br\/><br\/>⚽ Youth Sports Partnerships<\/p>","text_style":"body"}},"button_3mfb4N":{"type":"button","disabled":true,"settings":{"button_label":"Shop Now","button_link":"shopify:\/\/collections\/all","button_style_secondary":false}}},"block_order":["heading_NWakhK","text_xBg9Mk","button_3mfb4N"],"name":"Image with text v1","settings":{"page_width":true,"image":"shopify:\/\/shop_images\/5_copy_daa0e4e3-a0a4-459e-bdf3-347f960b22a2.jpg","mob_image":"shopify:\/\/shop_images\/5.jpg","contain":true,"cstm_padding":false,"height":"adapt","desktop_image_width":"medium","layout":"text_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"scheme-ae97f25d-9687-4460-bed4-d305a652f713","color_scheme":"scheme-ae97f25d-9687-4460-bed4-d305a652f713","padding_top":0,"padding_bottom":0,"margin_top":40,"margin_bottom":40}},"image_with_text_v1_3fNVpd":{"type":"image-with-text-v1","blocks":{"heading_cXfdwL":{"type":"heading","settings":{"heading":"the science","heading_size":"h0"}},"text_YiWChH":{"type":"text","settings":{"text":"<p><strong>Why Our Minerals Work<\/strong><\/p><p>Hydra is built differently at the mineral level.<\/p><p>Most hydration products use isolated, synthetic lab salts manufactured primarily for cost efficiency.<\/p><p>Hydra uses premium, nature-derived sea minerals sourced from one of the most mineral-dense environments available.<\/p><p>Our minerals are:<\/p><p>• In ionic form<br\/><br\/>• Naturally balanced<br\/><br\/>• Contain trace mineral complexity<br\/><br\/>• Designed to be easier on digestion<\/p>","text_style":"body"}},"button_AXxjV3":{"type":"button","disabled":true,"settings":{"button_label":"Shop Now","button_link":"shopify:\/\/collections\/all","button_style_secondary":false}}},"block_order":["heading_cXfdwL","text_YiWChH","button_AXxjV3"],"name":"Image with text v1","settings":{"page_width":true,"image":"shopify:\/\/shop_images\/4blue.jpg","mob_image":"shopify:\/\/shop_images\/Screen_Shot_2026-01-22_at_12.02.46_PM.png","contain":true,"cstm_padding":false,"height":"adapt","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"scheme-ae97f25d-9687-4460-bed4-d305a652f713","color_scheme":"scheme-ae97f25d-9687-4460-bed4-d305a652f713","padding_top":0,"padding_bottom":0,"margin_top":40,"margin_bottom":40}},"rich_text_Dyte98":{"type":"rich-text","blocks":{"text_UfpPKx":{"type":"text","settings":{"text":"<p><\/p><p><strong>Why Ionic Form Matters<\/strong><\/p><p>Ionic minerals are already dissolved and electrically charged in solution.<\/p><p>That means:<\/p><p>• They do not need to be broken down by digestion<br\/><br\/>• They are immediately available in solution<br\/><br\/>• They are closer to how electrolytes exist in the body<\/p><p>This supports smoother absorption and better cellular hydration.<\/p><p><strong>Why Source Matters<\/strong><\/p><p>Synthetic salts are typically isolated single compounds.<\/p><p>Nature-derived mineral sources contain a broader trace mineral profile and a naturally balanced ratio of sodium, potassium, and supporting minerals.<\/p><p>It is not about hype.<\/p><p>It is about balance, bioavailability, and better tolerance.<\/p><p>Hydration should feel smooth, not harsh.<\/p>"}}},"block_order":["text_UfpPKx"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"left","content_alignment":"left","color_