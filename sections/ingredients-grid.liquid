{{ 'ingredients-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    --ing-bg: {{ section.settings.bg_color }};
    --ing-heading-color: {{ section.settings.heading_color }};
    --ing-text-color: {{ section.settings.text_color }};
    --ing-card-bg: {{ section.settings.card_bg_color }};
    --ing-badge-bg: {{ section.settings.badge_bg_color }};
    --ing-badge-text: {{ section.settings.badge_text_color }};
    --ing-taste-bg: {{ section.settings.taste_bg_color }};
    --ing-protip-bg: {{ section.settings.protip_bg_color }};
    --ing-protip-label-bg: {{ section.settings.protip_label_bg }};
    --ing-protip-text: {{ section.settings.protip_text_color }};
    --ing-card-cols: {{ section.settings.card_cols }};
    --ing-card-gap-v: {{ section.settings.card_gap_v }}px;
    --ing-card-gap-h: {{ section.settings.card_gap_h }}px;
    --ing-img-size: {{ section.settings.img_size }}px;
    --ing-card-inner-gap: {{ section.settings.card_inner_gap }}px;
    --ing-taste-icon-size: {{ section.settings.taste_icon_size }}px;
    --ing-layout-cols: {{ section.settings.heading_col_width }}px 1fr;
    --ing-layout-gap: {{ section.settings.layout_gap }}px;
    --ing-taste-ml: calc({{ section.settings.heading_col_width }}px + {{ section.settings.layout_gap }}px);
    --ing-side-pad: {{ section.settings.side_padding }}px;
    --ing-max-width: {{ section.settings.content_max_width }}px;
  }
{% endstyle %}

{%- liquid
  assign ingredient_blocks = section.blocks | where: 'type', 'ingredient'
-%}

<section
  class="ingredients-grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div
    class="ingredients-grid__container"
  >

    <div
      class="ingredients-grid__layout"
    >

      {%- comment -%} Sticky heading left {%- endcomment -%}
      <div class="ingredients-grid__heading-wrap">
        {%- if section.settings.heading != blank -%}
          <h2
            class="ingredients-grid__heading"
            style="
              font-size: {{ section.settings.heading_size }}px;
              font-weight: {{ section.settings.heading_weight }};
              letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
              margin-bottom: {{ section.settings.heading_mb }}px;
            "
          >{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p
            class="ingredients-grid__subheading"
            style="
              font-size: {{ section.settings.subheading_size }}px;
              color: var(--ing-text-color);
              margin: 0;
              line-height: 1.6;
            "
          >{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Ingredient cards grid {%- endcomment -%}
      <div
        class="ingredients-grid__cards"
      >
        {%- for block in ingredient_blocks -%}
          <div
            class="ingredient-card"
            style="
              padding: {{ section.settings.card_padding }}px;
              border-radius: {{ section.settings.card_radius }}px;
            "
            {{ block.shopify_attributes }}
          >

            <div
              class="ingredient-card__image-wrap{% if block.settings.image == blank %} ingredient-card__image-wrap--placeholder{% endif %}"
              style="border-radius: {{ section.settings.img_radius }}px;"
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 220 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                  width="{{ section.settings.img_size }}"
                  height="{{ section.settings.img_size }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="ingredient-card__body">
              {%- if block.settings.name != blank -%}
                <h3
                  class="ingredient-card__name"
                  style="font-size: {{ section.settings.card_name_size }}px; font-weight: {{ section.settings.card_name_weight }}; letter-spacing: {{ section.settings.card_name_letter_spacing | divided_by: 100.0 }}em; margin-bottom: {{ section.settings.card_name_mb }}px;"
                >{{ block.settings.name }}</h3>
              {%- endif -%}

              {%- if block.settings.badge != blank -%}
                <div
                  class="ingredient-card__badge"
                  style="font-size: {{ section.settings.badge_size }}px; margin-bottom: {{ section.settings.badge_mb }}px;"
                >
                  <span class="ingredient-card__badge-icon">
                    <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2 7l3.5 3.5L12 3"/>
                    </svg>
                  </span>
                  {{ block.settings.badge }}
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p
                  class="ingredient-card__desc"
                  style="font-size: {{ section.settings.card_desc_size }}px;"
                >{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Taste banner {%- endcomment -%}
    {%- assign show_taste = false -%}
    {%- if section.settings.taste_title != blank or section.settings.taste_desc != blank or section.settings.protip_text != blank -%}
      {%- assign show_taste = true -%}
    {%- endif -%}

    {%- if show_taste -%}
      <div
        class="ingredients-grid__taste"
        style="margin-top: {{ section.settings.taste_mt }}px;"
      >
        <div
          class="taste-card"
          style="border-radius: {{ section.settings.taste_radius }}px; padding: {{ section.settings.taste_padding }}px {{ section.settings.taste_padding }}px 0;"
        >

          <div class="taste-card__left" style="padding-bottom: {{ section.settings.taste_padding }}px;">
            {%- if section.settings.taste_title != blank -%}
              {%- if section.settings.taste_icon != 'none' -%}
                <div class="taste-card__icon">
                  {%- case section.settings.taste_icon -%}
                    {%- when 'cup' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 8h1a4 4 0 0 1 0 8h-1" stroke-linecap="round"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 2v3M10 2v3M14 2v3" stroke-linecap="round"/></svg>
                    {%- when 'sparkle' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.6H22l-6.2 4.5 2.4 7.6L12 17.2l-6.2 4.5 2.4-7.6L2 9.6h7.6z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/></svg>
                    {%- when 'droplet' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.7c0 0-6.5 7.3-6.5 11.8a6.5 6.5 0 0 0 13 0C18.5 10 12 2.7 12 2.7z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M10 15.5c0-1.5 1-2.5 2-3" stroke="#fff" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
                    {%- when 'bolt' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M13 2L4.5 13H12l-1 9L19.5 11H12l1-9z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round" stroke-linecap="round"/></svg>
                    {%- when 'leaf' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 8C8 10 5.9 16.17 3.82 22c4.8-3 8.14-6.38 9.18-11 4.28.31 7.5 2.65 7.5 7 0 3-1.5 6-3.5 8" stroke="#fff" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/></svg>
                    {%- when 'check' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 6L9 17l-5-5" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l7 3.5v5c0 5-3 9.5-7 11-4-1.5-7-6-7-11v-5L12 2z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- when 'flame' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 22c4.97 0 7-3.58 7-7 0-3.07-2-5.64-4-7.5-.6-.56-1-.43-1 .5 0 1.5-.5 3-2 4-1-.5-2-2-2-4 0-1.5-.5-3.5-2-5-1 1.5-3 4-3 8 0 4.5 2.5 11 7 11z" stroke="#fff" stroke-width="1.5" fill="none" stroke-linejoin="round"/></svg>
                  {%- endcase -%}
                </div>
              {%- endif -%}
              <h3
                class="taste-card__title"
                style="font-size: {{ section.settings.taste_title_size }}px; margin-bottom: {{ section.settings.taste_title_mb }}px;"
              >{{ section.settings.taste_title }}</h3>
            {%- endif -%}
            {%- if section.settings.taste_desc != blank -%}
              <p
                class="taste-card__desc"
                style="font-size: {{ section.settings.taste_desc_size }}px;"
              >{{ section.settings.taste_desc }}</p>
            {%- endif -%}
          </div>

          {%- if section.settings.taste_image != blank -%}
            <div class="taste-card__image-wrap">
              <img
                src="{{ section.settings.taste_image | image_url: width: 400 }}"
                alt="{{ section.settings.taste_image.alt | default: 'Product' | escape }}"
                loading="lazy"
                style="max-height: {{ section.settings.taste_img_height }}px;"
              >
            </div>
          {%- else -%}
            <div class="taste-card__image-wrap"></div>
          {%- endif -%}

          {%- if section.settings.protip_text != blank -%}
            <div
              class="taste-card__pro-tip"
              style="border-radius: {{ section.settings.protip_radius }}px; padding: {{ section.settings.protip_padding }}px; margin-bottom: {{ section.settings.taste_padding }}px;"
            >
              {%- if section.settings.protip_label != blank -%}
                <span
                  class="taste-card__pro-tip-label"
                  style="font-size: {{ section.settings.protip_label_size }}px;"
                >{{ section.settings.protip_label }}</span>
              {%- endif -%}
              <p
                class="taste-card__pro-tip-text"
                style="font-size: {{ section.settings.protip_text_size }}px;"
              >{{ section.settings.protip_text }}</p>
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Ingredients Grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Max content width",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1340
    },
    {
      "type": "range",
      "id": "heading_col_width",
      "label": "Heading column width",
      "min": 160,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "layout_gap",
      "label": "Gap between heading and cards",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What's Inside Every Pop & Drop:"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": -10,
      "max": 50,
      "step": 1,
      "default": -2,
      "info": "Values in hundredths of an em (e.g. -2 = -0.02em)"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_mb",
      "label": "Heading bottom spacing",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Card Grid"
    },
    {
      "type": "select",
      "id": "card_cols",
      "label": "Cards per row",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "card_gap_v",
      "label": "Card row gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_gap_h",
      "label": "Card column gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card inner padding",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Card Image"
    },
    {
      "type": "range",
      "id": "img_size",
      "label": "Image size (width & height)",
      "min": 60,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 108
    },
    {
      "type": "range",
      "id": "img_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_inner_gap",
      "label": "Gap between image and text",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Card Typography"
    },
    {
      "type": "range",
      "id": "card_name_size",
      "label": "Ingredient name size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_name_letter_spacing",
      "label": "Name letter spacing",
      "min": -5,
      "max": 30,
      "step": 1,
      "default": 0,
      "info": "Values in hundredths of an em (e.g. 2 = 0.02em)"
    },
    {
      "type": "select",
      "id": "card_name_weight",
      "label": "Name font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "card_name_mb",
      "label": "Name bottom spacing",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "Badge text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_mb",
      "label": "Badge bottom spacing",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_desc_size",
      "label": "Description text size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Taste Banner"
    },
    {
      "type": "select",
      "id": "taste_icon",
      "label": "Taste banner icon",
      "options": [
        { "value": "cup",     "label": "Cup (default)" },
        { "value": "sparkle", "label": "Sparkle / Star" },
        { "value": "droplet", "label": "Water Droplet" },
        { "value": "bolt",    "label": "Lightning / Energy" },
        { "value": "leaf",    "label": "Leaf" },
        { "value": "heart",   "label": "Heart" },
        { "value": "check",   "label": "Checkmark" },
        { "value": "shield",  "label": "Shield / Verified" },
        { "value": "flame",   "label": "Flame" },
        { "value": "none",    "label": "No icon" }
      ],
      "default": "cup"
    },
    {
      "type": "range",
      "id": "taste_icon_size",
      "label": "Taste icon size (px)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "text",
      "id": "taste_title",
      "label": "Taste title",
      "default": "What do they taste like?"
    },
    {
      "type": "range",
      "id": "taste_title_size",
      "label": "Taste title size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "taste_title_mb",
      "label": "Title bottom spacing",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "textarea",
      "id": "taste_desc",
      "label": "Taste description",
      "default": "Our pops come in Apple, Strawberry, and Lime — bright, refreshing flavors with zero artificial sweeteners or aftertaste."
    },
    {
      "type": "range",
      "id": "taste_desc_size",
      "label": "Taste description size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "image_picker",
      "id": "taste_image",
      "label": "Taste image (mug / product shot)"
    },
    {
      "type": "range",
      "id": "taste_img_height",
      "label": "Taste image max height",
      "min": 80,
      "max": 320,
      "step": 8,
      "unit": "px",
      "default": 176
    },
    {
      "type": "range",
      "id": "taste_mt",
      "label": "Taste banner top spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "taste_radius",
      "label": "Taste banner border radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "taste_padding",
      "label": "Taste banner padding",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Pro Tip Box"
    },
    {
      "type": "text",
      "id": "protip_label",
      "label": "Pro tip label",
      "default": "Pro Tip:"
    },
    {
      "type": "range",
      "id": "protip_label_size",
      "label": "Pro tip label size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "textarea",
      "id": "protip_text",
      "label": "Pro tip text",
      "default": "Try adding Hydra Drops to any cold drink — sparkling water, lemonade, or straight from the bottle. A few drops go a long way."
    },
    {
      "type": "range",
      "id": "protip_text_size",
      "label": "Pro tip text size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "protip_radius",
      "label": "Pro tip box border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
