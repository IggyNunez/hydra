    "science_process_prod": {
      "type": "science-process",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "title": "Sourced from the Great Salt Lake",
            "text": "Our electrolytes begin as mineral-rich brine from the Great Salt Lake in Utah — one of the most concentrated inland mineral sources on Earth."
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "title": "3-Year Solar Evaporation",
            "text": "The brine is channeled into solar evaporation ponds where it concentrates naturally over three years — no chemical processing, no shortcuts."
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "title": "Full-Spectrum Mineral Harvest",
            "text": "The result is a naturally concentrated mineral complex containing sodium, potassium, magnesium, chloride, and over 72 trace minerals."
          }
        },
        "step_4": {
          "type": "step",
          "settings": {
            "title": "GRAS Certified & Lab Tested",
            "text": "Every batch is independently tested for heavy metals, microplastics, and contaminants. Classified as Generally Recognized As Safe (GRAS) for food and beverage use."
          }
        },
        "step_5": {
          "type": "step",
          "settings": {
            "title": "Blended Into Every Pop & Drop",
            "text": "These real sea minerals are blended into our Hydra Pops and Hydra Drops — delivering clean electrolyte hydration your body actually recognizes and absorbs."
          }
        }
      },
      "block_order": [
