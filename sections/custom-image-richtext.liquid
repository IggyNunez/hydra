<style>
.custom-image-richtext__inner {
    display: flex;
    align-items: center;
    padding: 4rem;
    gap: 20px;
    position: relative;
}
 .custom-image-richtext__image{
   min-width:180px;
 }
.custom-image-richtext__image img {
    width: 230px;
    max-width: 100%;
    display: block;
    {% comment %} position:absolute;
    top:-30%;
    left:0; {% endcomment %}
}

.custom-image-richtext__content {
  flex: 1;
}

.custom-image-richtext__heading {
  font-size:36px;
  margin:30px 0 10px;
  color:{{ section.settings.text_color }};
}

.custom-image-richtext__text {
 color:{{ section.settings.text_color }};
 margin:0;
 margin-bottom:30px;
 font-size: 20px;
 max-width: 600px;
}

.custom-image-richtext__link {
  color: {{ section.settings.text_color }};
  text-decoration: none;
  border-bottom: 1px solid;
  display: inline-block;
  line-height: 1.2;
}

.section-{{ section.id }}-padding .custom-image-richtext{
  background-color: {{ section.settings.background_color }};
}
.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
}
@media screen and (max-width:900px){
 .custom-image-richtext__heading {
  font-size:28px;
  margin:20px 0 10px;
}

.custom-image-richtext__text {
  margin-bottom:20px;
  font-size:15px;
 }
}

@media screen and (max-width:749px){
 .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
  }

  .custom-image-richtext__inner{
   flex-direction:column;
   gap:0px;
 }
 .custom-image-richtext__image{
   min-width:unset;
 }
 .custom-image-richtext__image img{
    position:static;
    width:200px;
 }
  .custom-image-richtext__heading {
    margin-top:0;
    text-align:center;
 }
 .custom-image-richtext__text{
   text-align:center;
 }
 .custom-image-richtext__link{
   margin-bottom:30px;
 }
}
</style>



<div class="custom-image-richtext-section">
  <div class="section-{{ section.id }}-padding">
    <div class="custom-image-richtext">
        <div class="custom-image-richtext__inner page-width">
            {% if section.settings.image != blank %}
            <div class="custom-image-richtext__image">
                <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.heading | escape }}">
            </div>
            {% endif %}
            
            <div class="custom-image-richtext__content">
            {% if section.settings.heading != blank %}
                <h2 class="custom-image-richtext__heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.text != blank %}
                <p class="custom-image-richtext__text">{{ section.settings.text }}</p>
            {% endif %}
            </div>
             {% if section.settings.link != blank and section.settings.link_label != blank %}
                <a href="{{ section.settings.link }}" class="custom-image-richtext__link">
                {{ section.settings.link_label }}
                </a>
            {% endif %}
        </div>
        </div>
  </div>
</div>
 
{% schema %}
{
  "name": "Custom Image Richtext",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "100% Organic Guarantee"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "We’re committed to using only pure, plant-based, and toxin-free ingredients in every product."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link Label",
      "default": "Learn More"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#6C9B58"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom Image Richtext",
      "category": "Custom"
    }
  ]
}
{% endschema %}