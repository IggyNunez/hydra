          "label": "Text value (if text type)",
          "default": ""
        },
        {
          "type": "header",
          "content": "Brand 3"
        },
        {
          "type": "select",
          "id": "brand_3_type",
          "label": "Cell type",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "cross", "label": "Cross" },
            { "value": "text", "label": "Text (positive)" },
            { "value": "text_neutral", "label": "Text (neutral)" },
            { "value": "text_bad", "label": "Text (negative)" }
          ],
          "default": "cross"
        },
        {
