{{ 'ingredients-grid.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    --ing-bg: {{ section.settings.bg_color }};
    --ing-heading-color: {{ section.settings.heading_color }};
    --ing-text-color: {{ section.settings.text_color }};
    --ing-card-bg: {{ section.settings.card_bg_color }};
    --ing-badge-bg: {{ section.settings.badge_bg_color }};
    --ing-badge-text: {{ section.settings.badge_text_color }};
    --ing-taste-bg: {{ section.settings.taste_bg_color }};
    --ing-protip-bg: {{ section.settings.protip_bg_color }};
    --ing-protip-label-bg: {{ section.settings.protip_label_bg }};
    --ing-protip-text: {{ section.settings.protip_text_color }};
    --ing-card-cols: {{ section.settings.card_cols }};
    --ing-card-gap-v: {{ section.settings.card_gap_v }}px;
    --ing-card-gap-h: {{ section.settings.card_gap_h }}px;
    --ing-img-size: {{ section.settings.img_size }}px;
    --ing-card-inner-gap: {{ section.settings.card_inner_gap }}px;
    --ing-layout-cols: {{ section.settings.heading_col_width }}px 1fr;
    --ing-layout-gap: {{ section.settings.layout_gap }}px;
    --ing-taste-ml: calc({{ section.settings.heading_col_width }}px + {{ section.settings.layout_gap }}px);
    --ing-side-pad: {{ section.settings.side_padding }}px;
    --ing-max-width: {{ section.settings.content_max_width }}px;
  }
{% endstyle %}

{%- liquid
  assign ingredient_blocks = section.blocks | where: 'type', 'ingredient'
-%}

<section
  class="ingredients-grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div
    class="ingredients-grid__container"
  >

    <div
      class="ingredients-grid__layout"
    >

      {%- comment -%} Sticky heading left {%- endcomment -%}
      <div class="ingredients-grid__heading-wrap">
        {%- if section.settings.heading != blank -%}
          <h2
            class="ingredients-grid__heading"
            style="
              font-size: {{ section.settings.heading_size }}px;
              font-weight: {{ section.settings.heading_weight }};
              margin-bottom: {{ section.settings.heading_mb }}px;
            "
          >{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p
            class="ingredients-grid__subheading"
            style="
              font-size: {{ section.settings.subheading_size }}px;
              color: var(--ing-text-color);
              margin: 0;
              line-height: 1.6;
            "
          >{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Ingredient cards grid {%- endcomment -%}
      <div
        class="ingredients-grid__cards"
      >
        {%- for block in ingredient_blocks -%}
          <div
            class="ingredient-card"
            style="
              padding: {{ section.settings.card_padding }}px;
              border-radius: {{ section.settings.card_radius }}px;
            "
            {{ block.shopify_attributes }}
          >

            <div
              class="ingredient-card__image-wrap{% if block.settings.image == blank %} ingredient-card__image-wrap--placeholder{% endif %}"
              style="border-radius: {{ section.settings.img_radius }}px;"
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 220 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                  width="{{ section.settings.img_size }}"
                  height="{{ section.settings.img_size }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="ingredient-card__body">
              {%- if block.settings.name != blank -%}
                <h3
                  class="ingredient-card__name"
                  style="font-size: {{ section.settings.card_name_size }}px; margin-bottom: {{ section.settings.card_name_mb }}px;"
                >{{ block.settings.name }}</h3>
              {%- endif -%}

              {%- if block.settings.badge != blank -%}
                <div
                  class="ingredient-card__badge"
                  style="font-size: {{ section.settings.badge_size }}px; margin-bottom: {{ section.settings.badge_mb }}px;"
                >
                  <span class="ingredient-card__badge-icon">
                    <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2 7l3.5 3.5L12 3"/>
                    </svg>
                  </span>
                  {{ block.settings.badge }}
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p
                  class="ingredient-card__desc"
                  style="font-size: {{ section.settings.card_desc_size }}px;"
                >{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Taste banner {%- endcomment -%}
    {%- assign show_taste = false -%}
    {%- if section.settings.taste_title != blank or section.settings.taste_desc != blank or section.settings.protip_text != blank -%}
      {%- assign show_taste = true -%}
    {%- endif -%}

    {%- if show_taste -%}
      <div
        class="ingredients-grid__taste"
        style="margin-top: {{ section.settings.taste_mt }}px;"
      >
        <div
          class="taste-card"
          style="border-radius: {{ section.settings.taste_radius }}px; padding: {{ section.settings.taste_padding }}px {{ section.settings.taste_padding }}px 0;"
        >

          <div class="taste-card__left" style="padding-bottom: {{ section.settings.taste_padding }}px;">
            {%- if section.settings.taste_title != blank -%}
              {%- if section.settings.show_taste_icon -%}
                <div class="taste-card__icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M17 8h1a4 4 0 0 1 0 8h-1" stroke-linecap="round"/>
                    <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V8z" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M6 2v3M10 2v3M14 2v3" stroke-linecap="round"/>
                  </svg>
                </div>
              {%- endif -%}
              <h3
                class="taste-card__title"
                style="font-size: {{ section.settings.taste_title_size }}px; margin-bottom: {{ section.settings.taste_title_mb }}px;"
              >{{ section.settings.taste_title }}</h3>
            {%- endif -%}
            {%- if section.settings.taste_desc != blank -%}
              <p
                class="taste-card__desc"
                style="font-size: {{ section.settings.taste_desc_size }}px;"
              >{{ section.settings.taste_desc }}</p>
            {%- endif -%}
          </div>

          {%- if section.settings.taste_image != blank -%}
            <div class="taste-card__image-wrap">
              <img
                src="{{ section.settings.taste_image | image_url: width: 400 }}"
                alt="{{ section.settings.taste_image.alt | default: 'Product' | escape }}"
                loading="lazy"
                style="max-height: {{ section.settings.taste_img_height }}px;"
              >
            </div>
          {%- else -%}
            <div class="taste-card__image-wrap"></div>
          {%- endif -%}

          {%- if section.settings.protip_text != blank -%}
            <div
              class="taste-card__pro-tip"
              style="border-radius: {{ section.settings.protip_radius }}px; padding: {{ section.settings.protip_padding }}px; margin-bottom: {{ section.settings.taste_padding }}px;"
            >
              {%- if section.settings.protip_label != blank -%}
                <span
                  class="taste-card__pro-tip-label"
                  style="font-size: {{ section.settings.protip_label_size }}px;"
                >{{ section.settings.protip_label }}</span>
              {%- endif -%}
              <p
                class="taste-card__pro-tip-text"
                style="font-size: {{ section.settings.protip_text_size }}px;"
              >{{ section.settings.protip_text }}</p>
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}

  </div>
</section>

