{{ 'science-process.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign step_blocks = section.blocks | where: 'type', 'step'
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --sp-bg: {{ section.settings.bg_color }};
    --sp-pt: {{ section.settings.padding_top }}px;
    --sp-pb: {{ section.settings.padding_bottom }}px;
    --sp-side: {{ section.settings.side_padding }}px;
    --sp-max-w: {{ section.settings.content_max_width }}px;
    --sp-header-mb: {{ section.settings.header_mb }}px;
    --sp-heading-color: {{ section.settings.heading_color }};
    --sp-text-color: {{ section.settings.text_color }};
    --sp-heading-size: {{ section.settings.heading_size }}px;
    --sp-heading-size-mob: {{ section.settings.heading_size_mobile }}px;
    --sp-heading-weight: {{ section.settings.heading_weight }};
    --sp-heading-ls: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --sp-heading-mb: {{ section.settings.heading_mb }}px;
    --sp-sub-size: {{ section.settings.subheading_size }}px;
    --sp-accent-color: {{ section.settings.accent_color }};
    --sp-accent-color-dim: {{ section.settings.accent_color | color_modify: 'alpha', 0.25 }};
    --sp-glow-color: {{ section.settings.glow_color }};
    --sp-step-gap: {{ section.settings.step_gap }}px;
    --sp-step-padding: {{ section.settings.step_padding }}px;
    --sp-step-radius: {{ section.settings.step_radius }}px;
    --sp-step-inner-gap: {{ section.settings.step_inner_gap }}px;
    --sp-step-bg: {{ section.settings.step_bg_color }};
    --sp-step-border-color: {{ section.settings.step_border_color }};
    --sp-step-num-bg: {{ section.settings.step_num_bg }};
    --sp-step-num-color: {{ section.settings.step_num_color }};
    --sp-step-num-ring: {{ section.settings.step_num_ring }};
    --sp-num-size: {{ section.settings.num_size }}px;
    --sp-num-font-size: {{ section.settings.num_font_size }}px;
    --sp-step-title-size: {{ section.settings.step_title_size }}px;
    --sp-step-title-mb: {{ section.settings.step_title_mb }}px;
    --sp-step-text-size: {{ section.settings.step_text_size }}px;
    --sp-connector-color: {{ section.settings.connector_color }};
    --sp-footer-mt: {{ section.settings.footer_mt }}px;
    --sp-footer-size: {{ section.settings.footer_text_size }}px;
    --sp-badge-bg: {{ section.settings.badge_bg }};
    --sp-badge-color: {{ section.settings.badge_color }};
    --sp-badge-border: {{ section.settings.badge_border }};
  }
{% endstyle %}

<section
  class="science-process"
  data-section-id="{{ section.id }}"
  data-science-process
>
  <div class="science-process__inner">

    {%- comment -%} HEADER {%- endcomment -%}
    <div class="science-process__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="science-process__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="science-process__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="science-process__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} STEPS {%- endcomment -%}
    {%- if step_blocks.size > 0 -%}
      <div class="science-process__steps">

        {%- comment -%} Animated connector line {%- endcomment -%}
        <div class="science-process__connector">
          <div class="science-process__connector-track"></div>
          <div class="science-process__connector-fill"></div>
        </div>

        {%- for block in step_blocks -%}
          <div
            class="science-process__step"
            data-step-index="{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            <div class="science-process__step-num">
              {{ forloop.index }}
            </div>
            <div class="science-process__step-body">
              {%- if block.settings.title != blank -%}
                <h3 class="science-process__step-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="science-process__step-text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} FOOTER {%- endcomment -%}
    {%- if section.settings.footer_text != blank or section.settings.badge_text != blank -%}
      <div class="science-process__footer">
        {%- if section.settings.footer_text != blank -%}
          <p class="science-process__footer-text">{{ section.settings.footer_text }}</p>
        {%- endif -%}
        {%- if section.settings.badge_text != blank -%}
          <div class="science-process__badges">
            {%- assign badges = section.settings.badge_text | split: '|' -%}
            {%- for badge in badges -%}
              <span class="science-process__badge">{{ badge | strip }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
<script src="{{ 'science-process.js' | asset_url }}" defer></script>

