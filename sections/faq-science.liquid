{{ 'faq-science.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign faq_blocks = section.blocks | where: 'type', 'faq_item'
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --faq-bg: {{ section.settings.bg_color }};
    --faq-pt: {{ section.settings.padding_top }}px;
    --faq-pb: {{ section.settings.padding_bottom }}px;
    --faq-side: {{ section.settings.side_padding }}px;
    --faq-max-w: {{ section.settings.content_max_width }}px;
    --faq-heading-size: {{ section.settings.heading_size }}px;
    --faq-heading-size-mob: {{ section.settings.heading_size_mobile }}px;
    --faq-heading-ls: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --faq-heading-weight: {{ section.settings.heading_weight }};
    --faq-heading-mb: {{ section.settings.heading_mb }}px;
    --faq-sub-size: {{ section.settings.subheading_size }}px;
    --faq-sub-mb: {{ section.settings.subheading_mb }}px;
    --faq-q-size: {{ section.settings.question_size }}px;
    --faq-a-size: {{ section.settings.answer_size }}px;
    --faq-item-gap: {{ section.settings.item_gap }}px;
    --faq-item-padding: {{ section.settings.item_padding }}px;
    --faq-item-radius: {{ section.settings.item_radius }}px;
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-text-color: {{ section.settings.text_color }};
    --faq-q-color: {{ section.settings.question_color }};
    --faq-item-bg: {{ section.settings.item_bg }};
    --faq-border-color: {{ section.settings.border_color }};
    --faq-icon-color: {{ section.settings.icon_color }};
  }
{% endstyle %}

<section class="faq-science{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
  <div class="faq-science__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="faq-science__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="faq-science__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if faq_blocks.size > 0 -%}
      <div class="faq-science__list">
        {%- for block in faq_blocks -%}
          <details class="faq-science__item" {{ block.shopify_attributes }}>
            <summary class="faq-science__question">
              <span>{{ block.settings.question }}</span>
              <svg class="faq-science__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-science__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "FAQ — Science",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 200, "step": 4, "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 200, "step": 4, "default": 80
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0, "max": 120, "step": 4, "default": 24
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600, "max": 1400, "step": 10, "default": 860
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 24, "max": 100, "step": 2, "default": 56
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 20, "max": 60, "step": 2, "default": 32
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": -10, "max": 50, "step": 1, "default": 2,
      "info": "In hundredths of an em"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_mb",
      "label": "Heading margin bottom",
      "min": 0, "max": 60, "step": 4, "default": 12
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12, "max": 24, "step": 1, "default": 16
    },
    {
      "type": "range",
      "id": "subheading_mb",
      "label": "Subheading margin bottom",
      "min": 0, "max": 80, "step": 4, "default": 40
    },
    {
      "type": "header",
      "content": "FAQ items"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question font size",
      "min": 14, "max": 28, "step": 1, "default": 18
    },
    {
      "type": "range",
      "id": "answer_size",
      "label": "Answer font size",
      "min": 12, "max": 22, "step": 1, "default": 15
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 0, "max": 32, "step": 2, "default": 12
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 12, "max": 40, "step": 2, "default": 24
    },
    {
      "type": "range",
      "id": "item_radius",
      "label": "Item border radius",
      "min": 0, "max": 24, "step": 2, "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#263d87"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / answer color",
      "default": "#ffffffcc"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "item_bg",
      "label": "Item background",
      "default": "#ffffff14"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Item border color",
      "default": "#ffffff1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Chevron icon color",
      "default": "#61c2f4"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ — Science",
      "settings": {
        "heading": "Frequently Asked Questions"
      },
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How do I use Hydra?", "answer": "<p>Hydra Pops: Freeze and enjoy as a hydrating popsicle, or drink straight from the pouch as a liquid shot. Hydra Drops: Add a few drops to any beverage — water, sparkling water, juice, smoothies — for an instant electrolyte boost.</p>" } }
      ]
    }
  ]
}
{% endschema %}
