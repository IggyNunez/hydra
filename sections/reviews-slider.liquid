{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{{ 'section-reviews-slider.css' | asset_url | stylesheet_tag }}

<div class="reviews-slider-section color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="page-width">
      <div class="header-wr {{ section.settings.header_alignment }}">
        {% if section.settings.desc_text != blank %}
          <p class="desc">
            {% if section.settings.enable_stars %}
              {% render 'rating-stars-icon' %}
            {% endif %}
            {{ section.settings.desc_text }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="{{ section.settings.heading_size }} heading hydra-main-title" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    </div>

    <div class="reviews-slider swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide review-slide">
            
          <div class="review-video-wrapper">
            {% if block.settings.video != blank %}
              {% assign video_image = block.settings.poster_image | default: block.settings.video.preview_image | img_url:'400x' %}
              {{ block.settings.video | video_tag: 
                autoplay: false, 
                controls: false, 
                loop: false, 
                muted: false, 
                playsinline: true, 
                class: 'my-review-video', 
                poster: video_image 
              }}
              
              <button class="video-play-btn">{% render 'play-icon' %}</button>
            {% endif %}
          </div>

            {% assign the_product = block.settings.vid_product %}
            {% if the_product != blank or the_product.available == false %}
              <div class="product-card">
                <a href="{{ the_product.url }}">
                  {% if the_product.featured_image %}
                    <img
                      src="{{ the_product.featured_image | image_url }}"
                      width="70"
                      height=""
                      alt="{{ the_product.featured_image.alt | escape }}"
                    />
                  {% endif %}
                </a>
                <div class="pdp-info">
                  <div class="info-left">
                    <h3 class="pdp-title">{{ the_product.title }}</h3>
                    <div class="price-area">
                      <span class="price">
                        {{ the_product.price_min | money }}
                      </span>
                      {% if the_product.compare_at_price_min > the_product.price_min %}
                        <span class="compare-price">
                          {{ the_product.compare_at_price_min | money }}
                        </span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="info-right">
                    <a class="pdp-link" href="{{ the_product.url }}">
                      {% render 'plus-custom-icon' %}
                    </a>
                  </div>
                </div>
              </div>
            {% endif %}
            
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var swiper = new Swiper(".reviews-slider", {
    slidesPerView: 4.8,
    loop: true,
    spaceBetween: 20,
    slidesPerGroup: 1,
    breakpoints: {
      320: {
        slidesPerView: 1.4,
        spaceBetween: 10
      },
      480: {
        slidesPerView: 1.8,
        spaceBetween: 15
      },
      768: {
        slidesPerView: 2.5,
        spaceBetween: 20
      },
      1024: {
        slidesPerView: 3.5,
      },
      1280: {
        slidesPerView: 4.8
      }
    },
    on: {
      init: function() {
        highlightCenterSlide(this);
      },
      slideChange: function() {
        highlightCenterSlide(this);
      }
    }
  });

    function highlightCenterSlide(swiperInstance) {
      swiperInstance.slides.forEach(function(slideEl) {
        slideEl.classList.remove('center-slide');
      });

      let offset = 2;
      let centerIndex = swiperInstance.activeIndex + offset;

      if (centerIndex >= swiperInstance.slides.length) {
        centerIndex = centerIndex % swiperInstance.slides.length;
      }

      swiperInstance.slides[centerIndex].classList.add('center-slide');
    }

    var reviewSlides = document.querySelectorAll('.review-slide');
    reviewSlides.forEach(function(slide) {
      var video = slide.querySelector('video');
      var playBtn = slide.querySelector('.video-play-btn');

      if (video && playBtn) {
        playBtn.addEventListener('click', function() {
          video.play();
          playBtn.classList.add('hidden');
        });

        video.addEventListener('click', function() {
          if (!video.paused) {
            video.pause();
            playBtn.classList.remove('hidden');
          }
        });

        video.addEventListener('ended', function() {
          playBtn.classList.remove('hidden');
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Reviews slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color"
    },
    {
      "type": "textarea",
      "id": "desc_text",
      "label": "Description text"
    },
    {
      "type": "checkbox",
      "id": "enable_stars",
      "default": false,
      "label": "Enable description stars"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Heading alignment"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Select video"
        },
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Poster image (optional)"
        },
        {
          "type": "product",
          "id": "vid_product",
          "label": "Select product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews slider"
    }
  ]
}
{% endschema %}
