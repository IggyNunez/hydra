    "faq_science_prod": {
      "type": "faq-science",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "How do I use Hydra?",
            "answer": "<p>Hydra Pops: Freeze and enjoy as a hydrating popsicle, or drink straight from the pouch as a liquid shot. Hydra Drops: Add a few drops to any beverage — water, sparkling water, juice, smoothies — for an instant electrolyte boost.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "What does it taste like?",
            "answer": "<p>Hydra Pops come in three refreshing flavors — Apple, Strawberry, and Lime — made with real fruit juice. Hydra Drops are flavorless and odorless, so they blend seamlessly into any drink without changing the taste.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Is it safe?",
            "answer": "<p>Absolutely. Our sea mineral electrolyte source (SolarSea Sport) is classified as GRAS — Generally Recognized As Safe — by the FDA. It's independently lab tested for heavy metals, microplastics, and contaminants.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Is this the same as sea salt?",
            "answer": "<p>No. While both come from natural sources, Hydra uses a concentrated mineral extract from the Great Salt Lake that delivers a full spectrum of electrolytes — sodium, potassium, magnesium, chloride, and 72+ trace minerals. It's not just salt — it's a complete mineral complex.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "What about microplastics?",
            "answer": "<p>The Great Salt Lake is an inland body of water, naturally isolated from ocean plastic contamination. Our mineral source is also independently tested to confirm it's free from microplastic content.</p>"
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "What about toxins in the Great Salt Lake?",
            "answer": "<p>Every batch of our sea mineral concentrate is independently tested for heavy metals, environmental contaminants, and microbial purity. The mineral extraction process concentrates beneficial electrolytes while screening out harmful substances.</p>"
          }
        }
      },
      "block_order": [
        "faq_1",
