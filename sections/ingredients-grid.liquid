    {
      "type": "image_picker",
      "id": "taste_image",
      "label": "Taste image (mug / product shot)"
    },
    {
      "type": "text",
      "id": "protip_label",
      "label": "Pro tip label",
      "default": "Pro Tip:"
    },
    {
      "type": "textarea",
      "id": "protip_text",
      "label": "Pro tip text",
