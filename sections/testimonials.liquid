{{ 'testimonials.css' | asset_url | stylesheet_tag }}

<testimonials-slider>
  <section class="testimonials">
    <div class="testimonials__container">
      <div class="testimonials__content">
        {% if section.settings.subtitle %}
          <p class="testimonials__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.heading %}
          <h2 class="testimonials__title">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <div class="testimonials__slider">
          <div class="swiper testimonials__swiper" data-testimonials-swiper>
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide">
                  <div class="testimonials__slide">
                    {% if block.settings.slide_img %}
                      <div class="testimonials__slide-media">
                        {% if block.settings.badge_text != blank %}
                          <p class="testimonials__slide-img-name testimonials__badge">
                            {{ block.settings.badge_text }}
                          </p>
                        {% endif %}
                        <img src="{{ block.settings.slide_img | image_url }}" alt="{{ block.settings.slide_img.alt }}">
                      </div>
                    {% endif %}
                    {% if block.settings.title != blank or block.settings.review != blank %}
                      <div class="testimonials__slide-desc">
                        <div class="testimonials__slide-icon">
                          <svg width="97" height="21" viewBox="0 0 97 21" fill="none" xmlns="http://www.w3.org/2000/svg">
