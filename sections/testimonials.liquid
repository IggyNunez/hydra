                            <path d="M69.0087 3.53557L70.8384 7.27939L74.8637 7.87052C75.2015 7.92682 75.483 8.15201 75.5956 8.4898C75.7082 8.79944 75.6237 9.16537 75.3704 9.39057L72.4429 12.2899L73.1466 16.3997C73.2029 16.7375 73.0622 17.0752 72.7807 17.2723C72.4992 17.4975 72.1332 17.4975 71.8236 17.3567L68.2205 15.4145L64.5893 17.3567C64.3078 17.4975 63.9419 17.4975 63.6604 17.2723C63.3789 17.0752 63.2381 16.7375 63.2944 16.3997L63.97 12.2899L61.0425 9.39057C60.8173 9.16537 60.7329 8.79944 60.8173 8.4898C60.9299 8.15201 61.2114 7.92682 61.5492 7.87052L65.6027 7.27939L67.4042 3.53557C67.5449 3.22593 67.8546 3.02889 68.2205 3.02889C68.5583 3.02889 68.8679 3.22593 69.0087 3.53557Z" fill="#EB8532"/>
