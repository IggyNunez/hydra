    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Check (yes) icon color",
      "default": "#263D87"
    },
    {
      "type": "color",
      "id": "cross_color",
      "label": "Cross (no) icon color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "vs_pill_color",
      "label": "VS pill text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#61c2f4"
    },
    {
      "type": "color",
      "id": "btn_text_color",
