          "settings": {
            "feature": "Vegan Formula",
            "we_have_it": true,
            "they_have_it": false
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Non-GMO Certified",
            "we_have_it": true,
            "they_have_it": false
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "200mg+ Electrolytes Per Serving",
