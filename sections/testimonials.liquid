                          </svg>
                        </div>
                        {% if block.settings.review != blank %}
                          <p class="testimonials__slide-text">
                            {{ block.settings.review }}
                          </p>
                        {% endif %}
                        {% if block.settings.title %}
                          <p class="testimonials__slide-name testimonials__badge">
                            {{ block.settings.title }}
                          </p>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
      <div class="testimonials__cta">
        {% if section.settings.btn_label %}
          <a class="subscribe-banner__btn btn btn--secondary" href="{{ section.settings.btn_link }}">{{ section.settings.btn_label }}</a>
        {% endif %}
      </div>
    </div>
  </section>
</testimonials-slider>

{% schema %}
  {
    "name": "Testimonials",
    "settings": [  
      {
        "type": "text",
        "label": "Subtitle",
        "id": "subtitle"
      },    
      {
        "type": "text",
        "label": "Heading",
        "id": "heading"
      },
      {
        "type": "text",
        "label": "Button Label",
        "id": "btn_label"
      },
      {
        "type": "url",
        "label": "Button URL",
        "id": "btn_link"
      }  
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "label": "Review Image",
            "id": "slide_img"
          },
          {
            "type": "text",
            "label": "Image Badge Text",
            "id": "badge_text"
          },
          {
            "type": "text",
            "label": "Name",
            "id": "title"
          },
          {
            "type": "textarea",
            "label": "Review Text",
            "id": "review"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Testimonials"
      }
    ]
  }
  {% endschema %}