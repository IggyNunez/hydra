  "presets": [
    {
      "name": "Brand Comparison",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Electrolyte Source",
            "brand_1_type": "text",
            "brand_1_text": "Natural Minerals",
            "brand_2_type": "text_bad",
            "brand_2_text": "Synthetic",
            "brand_3_type": "text_bad",
            "brand_3_text": "Synthetic",
            "brand_4_type": "text_bad",
            "brand_4_text": "Synthetic"
          }
        },
        {
          "type": "row",
