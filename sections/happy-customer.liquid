          </div>
          <div class="happy-customers__message">
            {{ section.settings.customers_count }}
          </div>
        </div>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="happy-customers__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    <div class="happy-customers__blocks">
      <div class="swiper happy-customers__swiper" data-happy-slider>
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <div class="happy-customers__block happy-customers__block--{{ forloop.index }}">
                {% if block.settings.video_poster != blank and block.settings.video_url != blank %}
                  <div class="happy-customers__media">
                    <a href="{{ block.settings.video_url }}" data-fancybox="group" class="happy-customers__media-link">
                      <span class="happy-customers__media-icon">
                        <svg width="69" height="69" viewBox="0 0 69 69" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="34.5" cy="34.5" r="34" fill="white" fill-opacity="0.14" stroke="white"/>
                          <path d="M47.5 33.634C48.1667 34.0189 48.1667 34.9811 47.5 35.366L28.75 46.1913C28.0833 46.5762 27.25 46.0951 27.25 45.3253L27.25 23.6747C27.25 22.9049 28.0833 22.4238 28.75 22.8087L47.5 33.634Z" fill="white"/>
                        </svg>
                      </span>
                      <img src="{{ block.settings.video_poster | image_url }}" alt="{{ block.settings.video_poster.alt }}">
                    </a>
                  </div>
                {% endif %}
                {% assign product = block.settings.product %}
                            {% if product != blank or product.available == false %}
                <div class="happy-customers__pdp">
                  <a href="{{ product.url }}" class="happy-customers__pdp-link"></a>
                  <div class="happy-customers__pdp-media">
                    <img src="{{ product.featured_image | image_url }}" alt="{{ product.featured_image.alt }}">
                  </div>
                  <div class="happy-customers__pdp-content">
                    <h6 class="happy-customers__pdp-title">{{ product.title }}</h6>
                    <div class="happy-customers__pdp-price">
                      <span class="happy-customers__pdp-price-regular">
                        {{ product.price | money }}
                      </span>
                      {% if product.compare_at_price %}
                        <span class="happy-customers__pdp-price-varies">
                          {{ product.compare_at_price_max | money }}
                        </span>
                      {% endif %}
                      <svg width="33" height="33" viewBox="0 0 33 33" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="33" height="33" rx="11" fill="#263D87"/>
                        <path d="M17.25 11.1406V15.7812H21.8906H22.9219V17.8438H21.8906H17.25V22.4844V23.5156H15.1875V22.4844V17.8438H10.5469H9.51562V15.7812H10.5469H15.1875V11.1406V10.1094H17.25V11.1406Z" fill="white"/>
                      </svg>
                    </div>
                  </div>
                </div>
            {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Happy Customers",
  "settings": [
    {
      "type": "text",
      "label": "Customers Count",
      "id": "customers_count"
    },
    {
      "type": "text",
      "label": "Heading",
      "id": "heading"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "label": "Add Video",
          "id": "video_url"
        },
        {
          "type": "image_picker",
          "label": "Add Video Poster",
          "id": "video_poster"
        },
        {
          "type": "product",
          "label": "Add Video Product",
          "id": "product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Happy Customers"
    }
  ]
}
{% endschema %}