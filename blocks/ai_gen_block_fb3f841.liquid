{% doc %}
  @prompt
    The 4 Electrolytes That Power Hydra 💧
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 20px;"> <div> <h4><strong>Sodium</strong></h4> <p>Maintains hydration balance and keeps your muscles firing.</p> </div> <div> <h4><strong>Potassium</strong></h4> <p>Prevents cramps and supports smooth muscle recovery.</p> </div> <div> <h4><strong>Magnesium</strong></h4> <p>Boosts energy, focus, and full-body performance.</p> </div> <div> <h4><strong>Chloride</strong></h4> <p>Keeps fluids in check so every cell stays perfectly hydrated.</p> </div> </div> <p style="margin-top: 20px;"><strong>Together:</strong> They work in sync to deliver full-body hydration that fuels every move.</p>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-electrolytes-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-electrolytes-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-electrolytes-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-electrolytes-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.footer_spacing }}px;
  }

  .ai-electrolytes-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-electrolytes-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
    font-weight: 700;
  }

  .ai-electrolytes-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-electrolytes-footer-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    font-size: {{ block.settings.footer_size }}px;
    color: {{ block.settings.footer_color }};
    line-height: 1.6;
  }

  .ai-electrolytes-footer-{{ ai_gen_id }} p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-electrolytes-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-electrolytes-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-electrolytes-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.9);
    }

    .ai-electrolytes-card-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_description_size }}px * 0.95);
    }
  }
{% endstyle %}

<div class="ai-electrolytes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-electrolytes-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-electrolytes-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <div class="ai-electrolytes-grid-{{ ai_gen_id }}">
      {% if block.settings.electrolyte_1_name != blank %}
        <div class="ai-electrolytes-card-{{ ai_gen_id }}">
          <h4 class="ai-electrolytes-card-title-{{ ai_gen_id }}">{{ block.settings.electrolyte_1_name }}</h4>
          <p class="ai-electrolytes-card-description-{{ ai_gen_id }}">{{ block.settings.electrolyte_1_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.electrolyte_2_name != blank %}
        <div class="ai-electrolytes-card-{{ ai_gen_id }}">
          <h4 class="ai-electrolytes-card-title-{{ ai_gen_id }}">{{ block.settings.electrolyte_2_name }}</h4>
          <p class="ai-electrolytes-card-description-{{ ai_gen_id }}">{{ block.settings.electrolyte_2_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.electrolyte_3_name != blank %}
        <div class="ai-electrolytes-card-{{ ai_gen_id }}">
          <h4 class="ai-electrolytes-card-title-{{ ai_gen_id }}">{{ block.settings.electrolyte_3_name }}</h4>
          <p class="ai-electrolytes-card-description-{{ ai_gen_id }}">{{ block.settings.electrolyte_3_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.electrolyte_4_name != blank %}
        <div class="ai-electrolytes-card-{{ ai_gen_id }}">
          <h4 class="ai-electrolytes-card-title-{{ ai_gen_id }}">{{ block.settings.electrolyte_4_name }}</h4>
          <p class="ai-electrolytes-card-description-{{ ai_gen_id }}">{{ block.settings.electrolyte_4_description }}</p>
        </div>
      {% endif %}
    </div>

    {% if block.settings.footer_text != blank %}
      <div class="ai-electrolytes-footer-{{ ai_gen_id }}">
        {{ block.settings.footer_text }}
      </div>
    {% endif %}
  </div>
</div>

