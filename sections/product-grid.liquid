{{ 'product-grid.css' | asset_url | stylesheet_tag }}
{{ 'custom-product-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- comment -%} GSAP + ScrollTrigger CDN {%- endcomment -%}
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer="defer"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer="defer"></script>
<script src="{{ 'product-grid.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --pg-cols: {{ section.settings.columns_desktop }};
    --pg-cols-mobile: {{ section.settings.columns_mobile }};
    --pg-gap: {{ section.settings.card_gap }}px;
    --pg-pt: {{ section.settings.padding_top }}px;
    --pg-pb: {{ section.settings.padding_bottom }}px;
    --pg-title-size: {{ section.settings.title_size }}px;
    --pg-title-ls: {{ section.settings.title_letter_spacing | divided_by: 100.0 }}em;
    --pg-subtitle-size: {{ section.settings.subtitle_size }}px;
    --pg-subtitle-ls: {{ section.settings.subtitle_letter_spacing | divided_by: 100.0 }}em;
    {%- if section.settings.bg_color != blank and section.settings.bg_color != 'rgba(0,0,0,0)' -%}
      --pg-bg: {{ section.settings.bg_color }};
    {%- endif -%}
    {%- if section.settings.heading_color != blank and section.settings.heading_color != 'rgba(0,0,0,0)' -%}
      --pg-heading-color: {{ section.settings.heading_color }};
    {%- endif -%}
    {%- if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' -%}
      --pg-text-color: {{ section.settings.text_color }};
    {%- endif -%}
    {%- if section.settings.accent_color != blank and section.settings.accent_color != 'rgba(0,0,0,0)' -%}
      --pg-accent-dot: {{ section.settings.accent_color }};
      --pg-subtitle-pill-bg: {{ section.settings.accent_color | color_modify: 'alpha', 0.08 }};
      --pg-subtitle-pill-border: {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }};
      --pg-glow-1: {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
      --pg-particle-color: {{ section.settings.accent_color | color_modify: 'alpha', 0.35 }};
      --pg-btn-bg-1: {{ section.settings.accent_color }};
      --pg-btn-bg-2: {{ section.settings.accent_color | color_darken: 15 }};
      --pg-mesh-1: {{ section.settings.accent_color | color_modify: 'alpha', 0.2 }};
      --pg-mesh-2: {{ section.settings.accent_color | color_modify: 'alpha', 0.15 | color_lighten: 20 }};
      --pg-mesh-3: {{ section.settings.accent_color | color_modify: 'alpha', 0.12 | color_lighten: 40 }};
    {%- endif -%}
    {%- if section.settings.show_bg_mesh -%}
      --pg-mesh-opacity: 1;
    {%- endif -%}
  }
{%- endstyle -%}

<section
  class="product-grid"
  data-particles="{{ section.settings.show_particles }}"
>
  {%- comment -%} Background mesh gradient {%- endcomment -%}
  {%- if section.settings.show_bg_mesh -%}
    <div class="product-grid__bg-mesh" aria-hidden="true"></div>
  {%- endif -%}

  {%- comment -%} Floating particles {%- endcomment -%}
  {%- if section.settings.show_particles -%}
    <div class="pg-particles" aria-hidden="true"></div>
  {%- endif -%}

  <div class="product-grid__container">

    {%- if section.settings.subtitle != blank or section.settings.title != blank or section.settings.description != blank -%}
      <div class="product-grid__header">

        {%- if section.settings.subtitle != blank -%}
          <p class="product-grid__subtitle">
            <span class="product-grid__subtitle-dot" aria-hidden="true"></span>
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="product-grid__title{% if section.settings.gradient_title %} product-grid__title--gradient{% endif %}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="product-grid__desc rte">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.show_divider -%}
          <div class="product-grid__divider" aria-hidden="true"></div>
        {%- endif -%}

        {%- if section.settings.collection != blank and section.settings.show_count -%}
          <div class="product-grid__count">
            <span class="product-grid__count-num">{{ section.settings.collection.products_count }}</span>
            products
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.collection != blank -%}
      <div class="product-grid__items">
        {%- assign skip_card_product_styles = false -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <div
            class="product-grid__item"
            style="--animation-order: {{ forloop.index }};"
          >
            {%- comment -%} Card glow overlay (cursor-following via JS) {%- endcomment -%}
            <div class="pg-card-glow" aria-hidden="true"></div>

            {%- comment -%} Card index number {%- endcomment -%}
            {%- if section.settings.show_card_index -%}
              <span class="pg-card-index" aria-hidden="true"></span>
            {%- endif -%}

            {%- render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              skip_styles: skip_card_product_styles,
              section_id: section.id,
              quick_add: section.settings.quick_add
            -%}
          </div>
          {%- assign skip_card_product_styles = true -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-grid__items">
        {%- for i in (1..section.settings.columns_desktop) -%}
          <div class="product-grid__item" style="--animation-order: {{ forloop.index }};">
            <div class="pg-card-glow" aria-hidden="true"></div>
            {%- assign placeholder_image = 'product-apparel-' | append: forloop.index -%}
            {%- render 'card-product',
              show_vendor: section.settings.show_vendor,
              media_aspect_ratio: section.settings.image_ratio,
              placeholder_image: placeholder_image
            -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_cta and section.settings.cta_text != blank -%}
      <div class="product-grid__cta">
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="product-grid__btn product-grid__btn--{{ section.settings.cta_style }}"
        >
          <span class="pg-btn-text">
            {{- section.settings.cta_text -}}
            <span class="pg-btn-arrow" aria-hidden="true">→</span>
          </span>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 25,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48,
      "label": "Title font size"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": -10,
      "max": 50,
      "step": 1,
      "default": -2,
      "label": "Title letter spacing",
      "info": "Values in hundredths of an em (e.g. -2 = -0.02em)"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13,
      "label": "Subtitle font size"
    },
    {
      "type": "range",
      "id": "subtitle_letter_spacing",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 10,
      "label": "Subtitle letter spacing",
      "info": "Values in hundredths of an em (e.g. 10 = 0.1em)"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" },
        { "value": "5", "label": "5 columns" },
        { "value": "6", "label": "6 columns" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20,
      "label": "Gap between cards"
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Card settings"
    },
    {
      "type": "select",
      "id": "quick_add",
      "label": "Quick add button",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "standard", "label": "Standard" }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show product rating",
      "default": false
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "show_card_index",
      "label": "Show card index numbers",
      "default": false,
      "info": "Displays 01, 02, 03... on card hover"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#7c4db8",
      "info": "Used for subtitle pill, glow ring, particles, button gradient"
    },
    {
      "type": "header",
      "content": "Visual effects"
    },
    {
      "type": "checkbox",
      "id": "gradient_title",
      "label": "Animated gradient title",
      "default": false,
      "info": "Title text shimmers with a gradient animation"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show decorative divider",
      "default": true,
      "info": "Gradient line below the header"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count badge",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_bg_mesh",
      "label": "Show background mesh gradient",
      "default": false,
      "info": "Subtle animated gradient overlay on section background"
    },
    {
      "type": "checkbox",
      "id": "show_particles",
      "label": "Show floating particles",
      "default": false,
      "info": "Soft floating dots in the background"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Gradient" },
        { "value": "secondary", "label": "Outline" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Bottom padding"
    }
  ],
  "presets": [
    {
      "name": "Product Grid",
      "settings": {
        "show_divider": true,
        "show_cta": true,
        "cta_text": "View All"
      }
    }
  ]
}
{% endschema %}
