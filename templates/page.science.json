        "text_purity": {
          "type": "text",
          "settings": {
            "text": "<p>Hydra's mineral source undergoes extensive laboratory testing to ensure purity and safety. Independent lab testing verifies heavy metal screening, purity across multiple mineral panels, and food-grade safety standards.</p><p>These minerals are classified as <strong>GRAS (Generally Recognized As Safe)</strong> for use in food and beverage products.</p>"
          }
        }
      },
